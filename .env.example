# Environment template - Copy to .env and fill in actual values
# WARNING: Never commit .env file to git!

# Application
ENVIRONMENT=production
LOG_LEVEL=info
PORT=8080

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/marketscout_db

# APIs & Keys
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Search APIs
SERPAPI_API_KEY=your-serpapi-key
NEWSAPI_KEY=your-newsapi-key
SHODAN_API_KEY=your-shodan-key

# GitHub Integration
GITHUB_TOKEN=your-github-token

# Semantic Search
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=./data/faiss_index

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Cloud Storage (optional)
GCS_BUCKET_NAME=market-scout-reports
AWS_S3_BUCKET=market-scout-reports
